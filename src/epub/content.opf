		<dc:title id="title">On a Pincushion</dc:title>
		<meta property="title-type" refines="#title">main</meta>
		<meta property="file-as" refines="#title">On a Pincushion</meta>
		<dc:title id="subtitle">And Other Fairy Tales</dc:title>
		<meta property="title-type" refines="#subtitle">subtitle</meta>
		<meta property="file-as" refines="#subtitle">And Other Fairy Tales</meta>
		<dc:title id="fulltitle">On a Pincushion, And Other Fairy Tales</dc:title>
		<meta property="file-as" refines="#fulltitle">On a Pincushion, And Other Fairy Tales</meta>
		<meta property="title-type" refines="#fulltitle">extended</meta>
		<dc:subject id="subject-1">Fairy Tales</dc:subject>
		<meta property="authority" refines="#subject-1">LCSH</meta>
		<meta property="term" refines="#subject-1">sh85046925</meta>
